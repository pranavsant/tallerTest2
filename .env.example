# ─────────────────────────────────────────
# Overseer AI — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── App ───────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Supabase ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── PostgreSQL (direct connection) ────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/overseer_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=overseer_ai
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Twilio ────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15550000000
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-or-domain.com

# ── ElevenLabs ────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2

# ── Next.js (public — exposed to browser) ─
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── WebSocket ─────────────────────────────
WS_HEARTBEAT_INTERVAL=30
