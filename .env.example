# ─────────────────────────────────────────────────────────────────────────────
# Overseer AI — Environment Variables
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your real secrets, then:
#   docker compose up --build
#
# Keys marked [required] must be set before the service will work correctly.
# Keys marked [optional] have safe defaults for local development.
# Keys marked [build-time] are baked into the Next.js bundle at `docker build`
#   time; changing them after a build has no effect without a rebuild.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                         # development | production
SECRET_KEY=change-me-to-a-long-random-string  # [required] used for token signing
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by the `db` container and injected into `api` / `migrate` by Compose.
POSTGRES_USER=postgres                      # [optional] default: postgres
POSTGRES_PASSWORD=password                  # [required] change in production
POSTGRES_DB=overseer_ai                     # [optional] default: overseer_ai
POSTGRES_HOST=db                            # Docker service name (do not change)
POSTGRES_PORT=5432                          # [optional] host-side published port

# Full DSN used by SQLAlchemy (asyncpg driver) — overridden by Compose to use
# the internal Docker hostname. Keep this value for local (non-Docker) dev.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/overseer_ai

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required if using Supabase as the repository backend.
SUPABASE_URL=https://your-project.supabase.co   # [required]
SUPABASE_SERVICE_KEY=your-supabase-service-role-key  # [required] server-side only
SUPABASE_JWT_SECRET=your-supabase-jwt-secret         # [required] for JWT validation

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # [required]
TWILIO_AUTH_TOKEN=your-twilio-auth-token               # [required]
TWILIO_PHONE_NUMBER=+15550000000                       # [required] your Twilio number
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-or-domain.com  # [required] public URL for TwiML callbacks

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key        # [required]
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM          # [optional] default voice
ELEVENLABS_MODEL_ID=eleven_turbo_v2               # [optional] default model

# ── Next.js public (browser-side) ─────────────────────────────────────────────
# These are [build-time] — they are baked into the JS bundle.
# NEXT_PUBLIC_API_BASE_URL must be reachable from the end-user's browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30                    # [optional] seconds between heartbeat pings

# ── Feed ingestion worker ───────────────────────────────────────────────────────
# Background polling/streaming scheduler that ingests configured feed sources.
FEED_INGESTION_ENABLED=true                 # [optional] master switch for the background poller
FEED_INGESTION_SYNC_INTERVAL=60             # [optional] seconds between feed-set rediscovery
